# DuckDB (native) specifics for the long-lived REPL-over-FIFO harness.
# Same as scenario-1 duckdb-parquet, but bound to the native hits.db table
# rather than a parquet view, and matching the vanilla load's storage version.

REPL_NAME="duckdb (native)"
REPL_CMD="duckdb hits.db -storage_version latest"
REPL_INIT_CMDS=$'.timer on'
REPL_SENTINEL_EMIT='.print %s'
REPL_PROBE_SQL='SELECT 1;'
REPL_QUIT='.quit'

repl_parse_timing() { awk '/^Run Time/ { print $5 }'; }
repl_result_filter() { grep -v '^Run Time ' | grep -v '^CBDONE_'; }
