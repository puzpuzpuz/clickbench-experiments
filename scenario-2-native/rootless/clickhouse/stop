#!/bin/bash
# ROOTLESS: stop the user-mode clickhouse-server (no sudo). Leaves ch-data in
# place so the next ./start (per-query restart) reopens the loaded table.
[ -f ch.pid ] && kill "$(cat ch.pid)" 2>/dev/null
for _ in $(seq 1 20); do
    ./clickhouse client --query "SELECT 1" >/dev/null 2>&1 || break
    sleep 0.5
done
rm -f ch.pid
exit 0
