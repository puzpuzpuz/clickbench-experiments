# DuckDB specifics for the long-lived REPL-over-FIFO harness.
# Sourced (after lib/fifo-repl.sh) by start/stop/check/query/load.

REPL_NAME="duckdb-parquet"
# Resident CLI: one duckdb process bound to hits.db for the whole run.
REPL_CMD="duckdb hits.db"
# Same session settings the vanilla query script applies per-process — except
# now parquet_metadata_cache actually gets to *persist* across queries, which
# is the entire point.
REPL_INIT_CMDS=$'.timer on\nSET parquet_metadata_cache=true;'
# `.print` is a dot-command (not timed), so it never emits its own Run Time
# line — the slice's only Run Time belongs to the real query.
REPL_SENTINEL_EMIT='.print %s'
REPL_PROBE_SQL='SELECT 1;'
REPL_QUIT='.quit'

# duckdb's `.timer on` prints: `Run Time (s): real <secs> user <s> sys <s>`.
repl_parse_timing() { awk '/^Run Time/ { print $5 }'; }
repl_result_filter() { grep -v '^Run Time ' | grep -v '^CBDONE_'; }
