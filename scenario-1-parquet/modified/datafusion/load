#!/bin/bash
# MODIFIED (keep-alive): register the external table + view ONCE in the
# resident session via `.load` (repl-engine.py runs the pristine create.sql).
set -e

# shellcheck source=../../../lib/fifo-repl.sh
source ../lib/fifo-repl.sh
# shellcheck source=./repl.env
source ./repl.env

if ! repl_query ".load" >/dev/null 2>&1; then
    echo "load: .load (create.sql) failed in resident DataFusion session" >&2
    exit 1
fi

# Stamp the exact engine build into the result (parsed by lib/log-to-json.py).
echo "Engine version: datafusion $(myenv/bin/python3 -c 'import importlib.metadata as m; print(m.version("datafusion"))' 2>/dev/null)"
sync
