# DataFusion keep-alive via the datafusion Python library, held resident by
# lib/repl-engine.py. datafusion-cli is a REPL but driving it over a FIFO is
# fragile; the library is the same engine kept alive in one SessionContext.
# Timing is perf_counter around .collect(), mirroring datafusion-cli's
# per-statement `Elapsed`.

REPL_NAME="datafusion (python)"
REPL_CMD="myenv/bin/python3 ../lib/repl-engine.py datafusion"
REPL_INIT_CMDS=""
REPL_SENTINEL_EMIT=".print %s"
REPL_PROBE_SQL="SELECT 1;"
REPL_QUIT=".quit"

repl_parse_timing() { awk '/^Run Time/ { print $5 }'; }
repl_result_filter() { grep -v '^Run Time ' | grep -v '^CBDONE_'; }
