#!/bin/bash
# MODIFIED (keep-alive): register the File(Parquet) table ONCE in the resident
# chdb session via the `.load` command (repl-engine.py reads the pristine
# upstream create.sql). The table — and clickhouse's marks/uncompressed caches
# — then persist across the hot runs.
set -e

# shellcheck source=../../../lib/fifo-repl.sh
source ../lib/fifo-repl.sh
# shellcheck source=./repl.env
source ./repl.env

if ! repl_query ".load" >/dev/null 2>&1; then
    echo "load: .load (create.sql) failed in resident chdb session" >&2
    exit 1
fi
sync
