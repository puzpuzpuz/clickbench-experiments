# ClickHouse keep-alive via chdb (clickhouse-local as an embedded library),
# held resident by lib/repl-engine.py. clickhouse-local's CLI can't be a clean
# FIFO REPL (it batches stdin until EOF; interactive needs a PTY and disables
# --time), so we keep the same engine alive as a library instead. Timing is
# chdb's reported `elapsed()` — the same internal query time `--time` reports.

REPL_NAME="clickhouse-parquet (chdb)"
REPL_CMD="myenv/bin/python3 ../lib/repl-engine.py chdb"
REPL_INIT_CMDS=""
REPL_SENTINEL_EMIT=".print %s"
REPL_PROBE_SQL="SELECT 1;"
REPL_QUIT=".quit"

# repl-engine.py emits a duckdb-style `Run Time (s): real <secs> ...` line.
repl_parse_timing() { awk '/^Run Time/ { print $5 }'; }
repl_result_filter() { grep -v '^Run Time ' | grep -v '^CBDONE_'; }
