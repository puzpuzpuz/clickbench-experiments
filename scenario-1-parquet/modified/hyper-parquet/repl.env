# Hyper keep-alive via tableauhyperapi, held resident by lib/repl-engine.py.
# Vanilla hyper-parquet spawns a fresh HyperProcess and re-runs create.sql on
# EVERY query (both outside the timed region); here one HyperProcess +
# Connection persists for the whole run. Timing is perf_counter around
# execute_list_query, exactly as the vanilla script times it — so this engine
# is the honest control: its per-call HyperProcess/create.sql tax was never in
# the recorded number, so keeping it alive should barely move the hot score.

REPL_NAME="hyper (python)"
REPL_CMD="myenv/bin/python3 ../lib/repl-engine.py hyper"
REPL_INIT_CMDS=""
REPL_SENTINEL_EMIT=".print %s"
REPL_PROBE_SQL="SELECT 1;"
REPL_QUIT=".quit"

repl_parse_timing() { awk '/^Run Time/ { print $5 }'; }
repl_result_filter() { grep -v '^Run Time ' | grep -v '^CBDONE_'; }
